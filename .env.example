# Picovoice (Wake Word)
# Obtener en: https://console.picovoice.ai/
PICOVOICE_API_KEY=tu_api_key_actual_de_picovoice

# Spotify API
# 1. Ir a https://developer.spotify.com/dashboard
# 2. Crear una app
# 3. Agregar http://localhost:8888/callback como Redirect URI
SPOTIFY_CLIENT_ID=tu_client_id_actual
SPOTIFY_CLIENT_SECRET=tu_client_secret_actual
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# Groq API (NUEVO - cloud LLM ultra-rápido)
# Obtener API key GRATIS en: https://console.groq.com
# Límites gratuitos: 30 req/min, 14,400 req/día
# NOTA: Solo el texto va a la nube, el audio de tu voz NUNCA sale de tu PC
GROQ_API_KEY=gsk_tu_key_de_groq_aqui